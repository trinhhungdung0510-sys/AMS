ENVIRONMENT=production

# Local dev (host): postgresql+psycopg://ams:ams_password@127.0.0.1:5432/ams
# Docker Compose: overridden by docker-compose.yml → postgres:5432
DATABASE_URL=postgresql+psycopg://user:password@host:5432/database

# Local dev: redis://127.0.0.1:6379/0
# Docker Compose: overridden by docker-compose.yml → redis:6379
REDIS_URL=redis://host:6379/0

JWT_SECRET_KEY=change-me-in-production

ACCESS_TOKEN_EXPIRE_MINUTES=60

CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://ams-rust-gamma.vercel.app

# FFmpeg/ffprobe for camera RTSP test and snapshot capture
FFPROBE_PATH=ffprobe
FFMPEG_PATH=ffmpeg
CAMERA_RTSP_TEST_TIMEOUT_SECONDS=15
CAMERA_SNAPSHOT_TIMEOUT_SECONDS=20
UPLOADS_ROOT=uploads

# Demo mode — no real camera / RTSP / AI required
DEMO_MODE=false
DEMO_AUTO_START=true
DEMO_SEED_ON_STARTUP=true
DEMO_SEED_COUNT=12
DEMO_INTERVAL_SECONDS=20
STRESS_TEST_ENABLED=false

# Notification Service (admin only — end users connect via Settings UI)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sender@gmail.com
SMTP_PASSWORD=your-google-app-password

ZALO_OA_ID=your-zalo-oa-id
ZALO_OA_ACCESS_TOKEN=your-zalo-oa-access-token
# ZALO_OA_FOLLOW_URL=https://zalo.me/your-oa-id
